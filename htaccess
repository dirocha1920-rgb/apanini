# SPA fallback for Hostinger / Apache: serve index.html for any unmatched route
# so client-side routing (TanStack Router) can handle /checkout, /produto/:id, etc.

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Pass through real files and directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise serve the SPA shell
  RewriteRule ^ index.html [L]
</IfModule>

# Long cache for hashed assets
<IfModule mod_headers.c>
  <FilesMatch "\.(js|css|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|avif|ico)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache"
  </FilesMatch>
</IfModule>
